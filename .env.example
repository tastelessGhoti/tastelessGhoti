# 환경 설정 예시 파일
# 실제 사용 시 .env 파일을 생성하고 아래 값들을 설정하세요
# .env 파일은 절대 Git에 커밋하지 마세요!

# Spring Profile (dev, prod)
SPRING_PROFILES_ACTIVE=dev

# JWT 설정
JWT_SECRET=ZWNvbW1lcmNlLXBvcnRmb2xpby1qd3Qtc2VjcmV0LWtleS1mb3ItYmFja2VuZC1kZXZlbG9wZXItbWluaW11bS01MTItYml0cw==
JWT_ACCESS_VALIDITY=3600000
JWT_REFRESH_VALIDITY=604800000

# 데이터베이스 설정
DB_URL=jdbc:h2:mem:ecommerce
DB_DRIVER=org.h2.Driver
DB_USERNAME=sa
DB_PASSWORD=
DB_POOL_SIZE=10

# 운영 환경 MySQL 예시
# DB_URL=jdbc:mysql://localhost:3306/ecommerce?useSSL=true&serverTimezone=Asia/Seoul
# DB_DRIVER=com.mysql.cj.jdbc.Driver
# DB_USERNAME=ecommerce_user
# DB_PASSWORD=your-secure-password
# DB_POOL_SIZE=20

# Redis 설정
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# CORS 설정 (운영 환경)
# 개발 환경에서는 설정하지 않으면 localhost만 허용됨
# ALLOWED_ORIGINS=https://your-domain.com,https://admin.your-domain.com

# MySQL Root 비밀번호 (Docker Compose 사용 시)
# MYSQL_ROOT_PASSWORD=your-root-password
